@{
    ViewData["Title"] = "Giriş Yap";
}

@section Styles {
    <style>
        body {
            background-image: url('/images/auth-bg.png');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
        }
        .auth-box {
            background: rgba(255, 255, 255, 0.95) !important;
            backdrop-filter: blur(10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1) !important;
            border: 1px solid rgba(255, 255, 255, 0.5);
        }
    </style>
}

<div class="main-content">
    <div class="box auth-box">
        <h3><span>Hoş Geldiniz</span>Giriş Yapın</h3>
        
        <form id="loginForm" class="auth-form">
            <div class="form-group">
                <label for="loginName">Kullanıcı Adı</label>
                <input type="text" id="loginName" class="form-control" required autocomplete="off">
            </div>
            <div class="form-group">
                <label for="loginPassword">Şifre</label>
                <input type="password" id="loginPassword" class="form-control" required>
            </div>
            
            <button type="submit" class="action-btn auth-btn">Giriş Yap</button>
        </form>
        
        <div id="auth-message-area"></div>
        
        <div class="auth-links">
            Hesabınız yok mu? <a href="/Home/Register">Kayıt olun</a>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/pages/auth.js?v=3"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            if (sessionStorage.getItem("loggedInUser")) {
                window.location.href = "/Home/Index";
            }
        });
    </script>
}
