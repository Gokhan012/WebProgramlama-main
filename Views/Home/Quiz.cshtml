@{
    ViewData["Title"] = "Quizopia";
}

@section Styles {
    <style>
        body {
            background-image: url('/images/main-bg.png');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
        }
    </style>
}

<div class="main-content">
    <div id="quiz-area" style="display: none;"></div>
    <div id="message-area"></div>

    <div id="nav-container" style="display: none; justify-content: space-between; align-items: center; margin-top: 32px; width: 440px;">
        <button id="prev-btn" class="nav-btn" onclick="oncekiSoru()" style="visibility: hidden;">&larr; Geri</button>
        <div id="pagination-bar" class="pagination-bar" style="margin-top: 0; width: auto;"></div>
        <button id="next-btn-small" class="nav-btn" onclick="siradakiSoru()">İleri &rarr;</button>
    </div>

    <button id="next-btn" class="action-btn" onclick="siradakiSoru()">Sonraki Soru &raquo;</button>
    <div style="display: flex; gap: 10px; justify-content: center; margin-top: 15px;">
        <button id="fetch-more-btn" class="action-btn" style="display: none; background-color: #3b82f6; border: none; margin: 0;" onclick="besSoruDahaGetir()">➕ 5 Soru Daha Getir</button>
        <button id="finish-btn" class="action-btn" style="display: none; margin: 0;" onclick="sinaviBitir()">Sınavı Bitir</button>
    </div>

    <div id="result-screen" style="display: none;">
        <h2 style="color: #2c3e50; margin-top: 0;">🎉 Sınav Tamamlandı!</h2>
        <p style="color: #7f8c8d; margin-bottom: 25px;">Sonuçlarınız aşağıda listelenmiştir.</p>
        <div class="stat stat-correct" id="score-correct"></div>
        <div class="stat stat-wrong" id="score-wrong"></div>
        <div class="stat stat-empty" id="score-empty"></div>
        
        <a href="javascript:location.reload()" class="restart-btn" style="margin-top: 30px; justify-content: center; background: #34495e; color: white;">
            <span class="icon">🔄</span> Sınavı Tekrar Et
        </a>
        <a href="/Home/Index" class="restart-btn" style="margin-top: 15px; justify-content: center; background: #10b981; color: white; border: none;">
            <span class="icon">🏠</span> Ana Ekrana Dön
        </a>
    </div>
</div>
