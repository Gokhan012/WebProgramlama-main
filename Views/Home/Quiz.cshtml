@{
    ViewData["Title"] = "Online Quiz Platformu";
}

<div class="main-content">
    
    <!-- Soru Sayısı Seçim Ekranı -->
    <div id="config-area" class="box" style="display: none; text-align: center; padding: 50px 40px; width: 440px; animation: fadeInSlide 0.4s ease-out;">
        <div style="font-size: 48px; margin-bottom: 20px;">⚙️</div>
        <h2 style="color: #0f172a; font-size: 24px; margin-top: 0; font-weight: 700;">Sınav Ayarları</h2>
        <p style="color: #64748b; font-size: 15px; line-height: 1.5; margin-bottom: 30px;">
            Soru sayısını seçiniz.
        </p>
        <div style="display: flex; flex-direction: column; gap: 12px; justify-content: center;">
            <button class="action-btn auth-btn" onclick="startWithQuestions(5)" style="background-color: #3b82f6; width: 100%; border: none;">5 Soru Getir</button>
            <button class="action-btn auth-btn" onclick="startWithQuestions(10)" style="background-color: #8b5cf6; width: 100%; border: none;">10 Soru Getir</button>
            <button class="action-btn auth-btn" onclick="startWithQuestions(25)" style="background-color: #ec4899; width: 100%; border: none;">25 Soru Getir</button>
        </div>
    </div>

    <div id="quiz-area"></div>
    <div id="message-area"></div>

    <div id="nav-container" style="display: flex; justify-content: space-between; align-items: center; margin-top: 32px; width: 440px;">
        <button id="prev-btn" class="nav-btn" onclick="oncekiSoru()" style="visibility: hidden;">&larr; Geri</button>
        <div id="pagination-bar" class="pagination-bar" style="margin-top: 0; width: auto;"></div>
        <button id="next-btn-small" class="nav-btn" onclick="siradakiSoru()">İleri &rarr;</button>
    </div>

    <button id="next-btn" class="action-btn" onclick="siradakiSoru()">Sonraki Soru &raquo;</button>
    <button id="finish-btn" class="action-btn" onclick="sinaviBitir()">Sınavı Bitir</button>

    <div id="result-screen">
        <h2 style="color: #2c3e50; margin-top: 0;">🎉 Sınav Tamamlandı!</h2>
        <p style="color: #7f8c8d; margin-bottom: 25px;">Sonuçlarınız aşağıda listelenmiştir.</p>
        <div class="stat stat-correct" id="score-correct"></div>
        <div class="stat stat-wrong" id="score-wrong"></div>
        <div class="stat stat-empty" id="score-empty"></div>
        
        <a href="javascript:location.reload()" class="restart-btn" style="margin-top: 30px; justify-content: center; background: #34495e; color: white;">
            <span class="icon">🔄</span> Sınavı Tekrar Et
        </a>
    </div>
</div>

@section Scripts {
    <script src="~/questions.js"></script>
}
